generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  passwordHash String
  passwordEncrypted String?
  name         String
  department   String?
  role         UserRole     @default(USER)
  mailQuotaMb  Int          @default(100)
  adminCredentialsShownAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  accounts     Account[]
  contacts     Contact[]
  sessions     UserSession[]
  prefetchStatus PrefetchStatus?
  addressBooks AddressBookUser[]
  labels       Label[]
  calendarEvents CalendarEvent[]
}

model AddressBook {
  id          String             @id @default(cuid())
  name        String
  description String?
  users       AddressBookUser[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model AddressBookUser {
  userId        String
  addressBookId String
  assignedAt    DateTime   @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  addressBook AddressBook @relation(fields: [addressBookId], references: [id], onDelete: Cascade)

  @@id([userId, addressBookId])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  password  String   // Encrypted
  adminManaged Boolean @default(false)
  name      String?
  senderName String?
  imapHost  String
  imapPort  Int      @default(993)
  smtpHost  String
  smtpPort  Int      @default(465)
  signature String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails    EmailMessage[]
  syncState MailSyncState[]

  @@unique([userId, email], name: "userId_email")
  @@index([userId])
}

model Contact {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email], name: "userId_email")
  @@index([userId])
}

model EmailMessage {
  id           String   @id @default(cuid())
  accountId    String
  folder       String
  uid          Int
  messageId    String?
  subject      String?
  from         String?
  to           String?
  date         DateTime?
  flags        String[] @default([])
  labels       String[] @default([])
  preview      String?
  inReplyTo    String?
  references   String?
  bodyHtml     String?
  bodyText     String?
  hasBody      Boolean  @default(false)
  attachments Json?
  toRecipients Json?
  ccRecipients Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, folder, uid], name: "account_folder_uid")
  @@index([accountId, folder, uid])
  @@index([accountId, folder, date])
}

model MailSyncState {
  id         String   @id @default(cuid())
  accountId  String
  folder     String
  lastUid    Int?
  lastSyncAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, folder], name: "account_folder_sync")
  @@index([accountId, folder])
}

model Label {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name], name: "userId_label_name")
  @@index([userId])
}

model CalendarEvent {
  id        String   @id @default(cuid())
  userId    String
  title     String
  location  String?
  startAt   DateTime
  endAt     DateTime
  color     String   @default("emerald")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startAt])
}

model PrefetchStatus {
  id          String   @id @default(cuid())
  userId      String   @unique
  status      String
  error       String?
  startedAt   DateTime
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
