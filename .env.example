DATABASE_URL="postgresql://uxmail:uxmailpassword@localhost:5432/uxmail_db?schema=public"
UXMAIL_START_POSTGRES="1"
UXMAIL_SETUP_DB="1"
ENCRYPTION_KEY="replace-with-a-long-random-string-at-least-32-chars"
ENCRYPTION_KEY_FILE=".uxmail.key"
BASIC_AUTH_USER="uxmail"
BASIC_AUTH_PASSWORD="replace-with-a-strong-password"
ADMIN_AUTO_LOGIN="1" # Auto-login only for admin dashboard when /api/auth/me?admin=1 is used.
POSTGRES_USER="uxmail"
POSTGRES_PASSWORD="uxmailpassword"
POSTGRES_DB="uxmail_db"
NC_BASE_URL="http://localhost:8080"
NC_PUBLIC_URL="http://localhost:8080"
NC_OAUTH_DATA_PATH="/nextcloud/data/oauth2-client.txt"
UXMAIL_PUBLIC_URL="http://localhost:3000"
SYNC_WORKER_INTERVAL_MS="300000"
SYNC_FETCH_LIMIT=""
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin"
ADMIN_NAME="Admin"
ADMIN_ATTACH_EXISTING="0"
