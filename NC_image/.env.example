# Kopiera till .env och ändra lösenord innan du startar
NC_PORT=8084

MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_PASSWORD=change_me_db_password

NC_ADMIN_USER=admin
NC_ADMIN_PASSWORD=change_me_admin_password
NC_TRUSTED_DOMAINS=localhost 127.0.0.1

DEMO_USER_1=demo1
DEMO_USER_1_PASSWORD=demo1_password
DEMO_USER_2=demo2
DEMO_USER_2_PASSWORD=demo2_password

# OAuth2 klient för mejlklienten (Uxmail callback som default)
OAUTH_CLIENT_NAME=uxmail-local
OAUTH_REDIRECT_URI=http://localhost:3000/api/nextcloud/auth/callback
